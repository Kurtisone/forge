# Copy this file to .env.local and adjust:
#   cp .env.example .env.local
#
# Every variable here has a working default in forge/config.py --
# you only need to uncomment/change what you want to override.
# Full explanations: README.md > Configuration.

# --- Provider selection --------------------------------------------------
# One of: llama_cpp | ollama | openrouter
# FORGE_PROVIDER=llama_cpp
# LLM_MODEL=default

# --- llama.cpp (default provider) -----------------------------------------
# Running under podman/Containerfile? 127.0.0.1 means the container
# itself, not your host. Point this at the host instead:
#   http://host.containers.internal:8080   (podman)
#   http://host.docker.internal:8080       (Docker Desktop)
# LLAMA_CPP_URL=http://127.0.0.1:8080
# LLAMA_CPP_TIMEOUT=120
# LLAMA_CPP_N_PREDICT=512

# --- Ollama -----------------------------------------------------------------
# Same container-networking note as LLAMA_CPP_URL above applies here.
# OLLAMA_URL=http://127.0.0.1:11434/api/generate

# --- OpenRouter ---------------------------------------------------------
# Required if FORGE_PROVIDER=openrouter. Get a key at openrouter.ai/keys.
# OPENROUTER_API_KEY=
# OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions

# --- Runtime safety -----------------------------------------------------
# Ceiling on router->tool steps per run. Multi-step only actually
# happens if the router response includes "done": false.
# MAX_STEPS=1

# --- Tools ----------------------------------------------------------------
# Only tools listed here are dispatchable, regardless of what a
# module implements. chat,code is the conservative default; add
# files/shell/git once you trust the sandboxing for your setup.
# ENABLED_TOOLS=chat,code,files,shell,git
# WORKSPACE_DIR=data/workspace
# SHELL_TIMEOUT=30
# SHELL_ALLOWED_COMMANDS=ls,cat,head,tail,wc,grep,find,python3,pip,pytest

# --- Memory ---------------------------------------------------------------
# MEMORY_ENABLED=true
# MEMORY_FILE=data/memory.json
# MEMORY_MAX_HISTORY=20

# --- Execution trace ------------------------------------------------------
# TRACE_ENABLED=true
# TRACE_FILE=data/traces.jsonl

# --- Debug ------------------------------------------------------------------
# SHOW_DEBUG=false

# --- API auth ---------------------------------------------------------------
# Empty = the HTTP API (/chat, /review, /run, /tools, /traces) stays open.
# Set this before exposing forge-core beyond localhost or a trusted LAN.
# API_TOKEN=

# --- API rate limiting -------------------------------------------------------
# In-memory sliding window, per client IP, single-process only.
# Applies to the same routes as API_TOKEN above.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=30
# RATE_LIMIT_WINDOW_SECONDS=60
